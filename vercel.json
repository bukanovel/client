{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/truyen", "destination": "/", "permanent": true },
    { "source": "/chinh-sach-bao-mat", "destination": "/privacy-policy", "permanent": true },
    { "source": "/dieu-khoan-su-dung", "destination": "/terms-of-service", "permanent": true }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
